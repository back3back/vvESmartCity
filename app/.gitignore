# --------------------------------------------------
# 1. 构建产物 (Build outputs)
# --------------------------------------------------
# 忽略所有目录下的 build 文件夹
/build/
**/build/

# Gradle 缓存和日志
.gradle/

# --------------------------------------------------
# 2. 本地配置文件 (Local configuration)
# --------------------------------------------------
# 本地 SDK 路径配置，绝对不要提交
local.properties

# 环境变量文件（如果使用了）
.env

# --------------------------------------------------
# 3. IDE 相关文件 (IntelliJ / Android Studio)
# --------------------------------------------------
# 忽略整个 .idea 文件夹（或者是只忽略特定的 workspace.xml 等，视团队规范而定）
# 这里建议忽略大部分用户特定的配置
.idea/
*.iml
*.iws

# Android Studio 的导航编辑器状态
.navigation/

# --------------------------------------------------
# 4. 系统临时文件 (OS generated files)
# --------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --------------------------------------------------
# 5. 签名密钥 (Signing keys - 如果你在这里生成的话)
# --------------------------------------------------
# 确保不要把你的发布密钥提交上去
*.jks
*.keystore

# --------------------------------------------------
# 6. 日志文件 (Logs)
# --------------------------------------------------
*.log
